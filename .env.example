# Personal Cloud Storage - Environment Configuration

# Secret key for JWT token signing (change this in production!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT token expiration time (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database URL
# SQLite (default): sqlite:///./app.db
# PostgreSQL: postgresql://user:password@localhost:5432/database_name
DATABASE_URL=sqlite:///./app.db

# File upload directory
FILES_DIR=./uploads

# Optional: Redis URL for Celery
# REDIS_URL=redis://localhost:6379/0

# Optional: API configuration
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
